# Local dev: leave TURSO_DATABASE_URL as-is for a local SQLite file (file:./local.db)
# Production: set both to your Turso credentials.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# 32+ char random string for cookie session signing.
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string
